<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">
    <fragment
    android:id="@+id/nav_home"
    android:name="com.example.itstore.fragment.HomeFragment"
    tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.itstore.fragment.ProfileFragment"
        tools:layout="@layout/fragment_profile" />
    <fragment
        android:id="@+id/nav_cart"
        android:name="com.example.itstore.fragment.CartFragment"
        tools:layout="@layout/fragment_cart" />
    <fragment
        android:id="@+id/nav_search"
        android:name="com.example.itstore.fragment.SearchFragment"
        android:label="fragment_search"
        tools:layout="@layout/fragment_search" >
        <action
            android:id="@+id/action_nav_search_to_nav_category_product"
            app:destination="@id/nav_category_product" />
    </fragment>
    <fragment
        android:id="@+id/nav_category_product"
        android:name="com.example.itstore.fragment.CategoryProductFragment"
        android:label="fragment_category_product"
        tools:layout="@layout/fragment_category_product" />


</navigation>